{
  "name": "gemmadesktop-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "gemma-desktop": "./dist/index.js",
    "gemmadesktop": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "cli": "npm run build && node dist/index.js",
    "lint": "eslint src tests vitest.config.ts --cache --max-warnings 0",
    "lint:fix": "eslint src tests vitest.config.ts --fix",
    "start": "node dist/index.js",
    "test": "npm run test:default",
    "test:default": "vitest run",
    "test:live": "npm run test:browser-live && npm run test:scenario-preflight",
    "test:browser-live": "GEMMA_DESKTOP_RUN_BROWSER_TOOL_LIVE=1 vitest run tests/tools/browserToolLive.test.ts",
    "test:scenario-preflight": "GEMMA_DESKTOP_RUN_CLI_SCENARIOS_LIVE=1 GEMMA_DESKTOP_CLI_SCENARIOS=web-hacker-news-frontpage vitest run tests/scenarios/scenariosLive.test.ts",
    "test:scenarios-live": "GEMMA_DESKTOP_RUN_CLI_SCENARIOS_LIVE=1 vitest run tests/scenarios/scenariosLive.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@gemma-desktop/sdk-core": "0.1.0",
    "@gemma-desktop/sdk-node": "0.1.0",
    "@gemma-desktop/sdk-runtime-llamacpp": "0.1.0",
    "@gemma-desktop/sdk-runtime-lmstudio": "0.1.0",
    "@gemma-desktop/sdk-runtime-omlx": "0.1.0",
    "@gemma-desktop/sdk-runtime-ollama": "0.1.0",
    "@gemma-desktop/sdk-tools": "0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.3.0",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  }
}
